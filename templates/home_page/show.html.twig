{% extends 'base.html.twig' %}

{% block title %}{{ product.name }}{% endblock %}

{% block javascripts %}
    {% block importmap %}{{ importmap(['app', 'home_page_show']) }}{% endblock %}
{% endblock %}

{% block body %}
<section class="product-detail-page">

    <div class="container product-detail">

        {# Produit principal #}
        <div class="product-main-card">
            <div class="row align-items-center g-5">

                <!-- Image produit -->
                <div class="col-md-6">
                    <div class="product-main-image-wrapper">
                        {% if product.image %}
                            <img src="{{ asset('uploads/images/' ~ product.image) }}"
                                 class="product-main-img"
                                 alt="{{ product.name }}">
                        {% else %}
                            <img src="https://via.placeholder.com/500x400"
                                 class="product-main-img"
                                 alt="Image indisponible">
                        {% endif %}
                    </div>
                </div>

                <!-- Infos produit -->
                <div class="col-md-6">
                    <div class="product-main-content">

                        <span class="product-kicker">
                            Produit sélectionné
                        </span>

                        <h1 class="product-main-title">
                            {{ product.name }}
                        </h1>

                        <div class="product-stock-badge {% if product.stock <= 0 %}is-out{% endif %}">
                            {% if product.stock > 0 %}
                                {{ product.stock }} en stock
                            {% else %}
                                Rupture de stock
                            {% endif %}
                        </div>

                        <p class="product-main-description">
                            {{ product.description }}
                        </p>

                        <p class="product-main-price">
                            {{ product.price|number_format(0, ',', ' ') }} €
                        </p>

                        <div class="product-main-actions">
                            {% if product.stock > 0 %}
                                <a href="{{ path('app_cart_add', {'id': product.id}) }}" class="btn-product-dark">
                                    Ajouter au panier
                                </a>
                            {% else %}
                                <button class="btn-product-dark disabled" disabled>
                                    Indisponible
                                </button>
                            {% endif %}

                            <a href="{{ path('app_home_page') }}" class="btn-product-light">
                                Retour
                            </a>
                        </div>

                    </div>
                </div>

            </div>
        </div>

        {# Derniers produits #}
        <div class="latest-products-heading">
            <span class="product-kicker">Découvrir aussi</span>
            <h2>Derniers produits ajoutés</h2>
        </div>

        <div class="row g-4">
            {% for product in products %}
                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="product-mini-card">

                        <a href="{{ path('app_home_product_show', {id: product.id}) }}" class="product-mini-image-link">
                            {% if product.image %}
                                <img src="{{ asset('uploads/images/' ~ product.image) }}"
                                     class="product-mini-img"
                                     alt="{{ product.name }}">
                            {% else %}
                                <img src="https://via.placeholder.com/300x200"
                                     class="product-mini-img"
                                     alt="Image indisponible">
                            {% endif %}
                        </a>

                        <div class="product-mini-body">
                            <a href="{{ path('app_home_product_show', {id: product.id}) }}" class="product-mini-title-link">
                                <h3 class="product-mini-title">
                                    {{ product.name }}
                                </h3>
                            </a>

                            <p class="product-mini-description">
                                {{ product.description|striptags|slice(0, 85) }}{% if product.description|length > 85 %}...{% endif %}
                            </p>

                            <div class="product-mini-bottom">
                                <p class="product-mini-price">
                                    {{ product.price|number_format(0, ',', ' ') }} €
                                </p>

                                {% if product.stock > 0 %}
                                    <a href="{{ path('app_cart_add', {'id': product.id}) }}" class="product-mini-cart-link">
                                        Ajouter au panier
                                    </a>
                                {% else %}
                                    <span class="product-mini-stock-out">
                                        Rupture de stock
                                    </span>
                                {% endif %}
                            </div>
                        </div>

                    </div>
                </div>
            {% else %}
                <p class="text-center">Aucun produit disponible.</p>
            {% endfor %}
        </div>

    </div>
</section>

<style>
    .product-detail-page {
        min-height: 100vh;
        padding: 120px 0 80px;
        background:
            radial-gradient(circle at top left, rgba(191, 161, 74, 0.10), transparent 32%),
            linear-gradient(180deg, #fbfaf7 0%, #f5f0e8 100%);
    }

    .product-detail {
        background: transparent;
    }

    .product-main-card {
        background: rgba(255, 255, 255, 0.92);
        border: 1px solid rgba(20, 20, 20, 0.06);
        border-radius: 30px;
        padding: clamp(24px, 4vw, 42px);
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.08);
    }

    .product-main-image-wrapper {
        width: 100%;
        aspect-ratio: 4 / 3;
        border-radius: 24px;
        overflow: hidden;
        background: #f4efe6;
        box-shadow: 0 18px 45px rgba(0, 0, 0, 0.10);
    }

    .product-main-img {
        width: 100%;
        height: 100%;
        display: block;
        object-fit: cover;
        object-position: center;
    }

    .product-main-content {
        max-width: 520px;
    }

    .product-kicker {
        display: inline-block;
        margin-bottom: 12px;
        color: #bfa14a;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
    }

    .product-main-title {
        margin: 0 0 16px;
        font-family: 'Playfair Display', serif;
        font-size: clamp(2.3rem, 4vw, 4rem);
        line-height: 1.02;
        font-weight: 700;
        color: #111;
        letter-spacing: -0.045em;
    }

    .product-stock-badge {
        display: inline-flex;
        width: fit-content;
        margin-bottom: 22px;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(191, 161, 74, 0.12);
        color: #8f7436;
        font-size: 0.9rem;
        font-weight: 700;
    }

    .product-stock-badge.is-out {
        background: rgba(217, 35, 50, 0.10);
        color: #b42318;
    }

    .product-main-description {
        margin: 0;
        color: #6f6961;
        font-family: 'Lora', serif;
        font-size: 1rem;
        line-height: 1.8;
    }

    .product-main-price {
        margin: 24px 0 0;
        font-family: 'Playfair Display', serif;
        font-size: 2rem;
        font-weight: 700;
        color: #bfa14a;
    }

    .product-main-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 28px;
    }

    .btn-product-dark,
    .btn-product-light {
        min-height: 48px;
        padding: 12px 26px;
        border-radius: 999px;
        font-weight: 700;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.25s ease;
    }

    .btn-product-dark {
        background: #111;
        color: #fff;
        border: 1px solid #111;
    }

    .btn-product-dark:hover {
        background: #bfa14a;
        border-color: #bfa14a;
        color: #111;
        transform: translateY(-2px);
        box-shadow: 0 12px 28px rgba(191, 161, 74, 0.28);
    }

    .btn-product-dark.disabled,
    .btn-product-dark:disabled {
        opacity: 0.55;
        cursor: not-allowed;
        transform: none;
        box-shadow: none;
    }

    .btn-product-light {
        background: #fff;
        color: #222;
        border: 1px solid rgba(20, 20, 20, 0.16);
    }

    .btn-product-light:hover {
        background: #111;
        border-color: #111;
        color: #fff;
        transform: translateY(-2px);
    }

    .latest-products-heading {
        margin: 74px auto 32px;
        text-align: center;
    }

    .latest-products-heading h2 {
        margin: 0;
        font-family: 'Playfair Display', serif;
        font-size: clamp(1.9rem, 3vw, 2.7rem);
        font-weight: 700;
        letter-spacing: -0.04em;
        color: #111;
    }

    .product-mini-card {
        height: 100%;
        min-height: 360px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        background: rgba(255, 255, 255, 0.96);
        border: 1px solid rgba(20, 20, 20, 0.06);
        border-radius: 22px;
        box-shadow: 0 14px 34px rgba(0, 0, 0, 0.075);
        transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    }

    .product-mini-card:hover {
        transform: translateY(-5px);
        border-color: rgba(191, 161, 74, 0.35);
        box-shadow: 0 20px 42px rgba(0, 0, 0, 0.12);
    }

    .product-mini-image-link {
        display: block;
        width: 100%;
        height: 185px;
        overflow: hidden;
        background: #f4efe6;
    }

    .product-mini-img {
        width: 100%;
        height: 100%;
        display: block;
        object-fit: cover;
        object-position: center;
        transition: transform 0.4s ease, filter 0.4s ease;
    }

    .product-mini-card:hover .product-mini-img {
        transform: scale(1.045);
        filter: saturate(1.03) contrast(1.02);
    }

    .product-mini-body {
        display: flex;
        flex-direction: column;
        flex: 1;
        padding: 18px 20px 20px;
    }

    .product-mini-title-link {
        color: inherit;
        text-decoration: none;
    }

    .product-mini-title {
        margin: 0 0 8px;
        font-family: 'Playfair Display', serif;
        font-size: 1.16rem;
        line-height: 1.15;
        font-weight: 700;
        color: #111;
        letter-spacing: -0.025em;
    }

    .product-mini-title-link:hover .product-mini-title {
        color: #bfa14a;
    }

    .product-mini-description {
        margin: 0 0 16px;
        color: #6f6961;
        font-family: 'Lora', serif;
        font-size: 0.88rem;
        line-height: 1.5;

        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .product-mini-bottom {
        margin-top: auto;
    }

    .product-mini-price {
        margin: 0 0 8px;
        font-family: 'Playfair Display', serif;
        font-size: 1.15rem;
        font-weight: 700;
        color: #bfa14a;
    }

    .product-mini-cart-link {
        display: inline-flex;
        width: fit-content;
        color: #111;
        font-size: 0.9rem;
        font-weight: 700;
        text-decoration: none;
        border-bottom: 1px solid #111;
        transition: color 0.2s ease, border-color 0.2s ease;
    }

    .product-mini-cart-link:hover {
        color: #bfa14a;
        border-color: #bfa14a;
    }

    .product-mini-stock-out {
        display: inline-flex;
        color: #b42318;
        font-size: 0.9rem;
        font-weight: 700;
    }

    @media (max-width: 768px) {
        .product-detail-page {
            padding: 100px 0 55px;
        }

        .product-main-card {
            border-radius: 24px;
        }

        .product-main-image-wrapper {
            aspect-ratio: 1 / 1;
        }

        .product-main-title {
            font-size: 2.2rem;
        }

        .product-main-price {
            font-size: 1.65rem;
        }

        .product-main-actions {
            width: 100%;
        }

        .btn-product-dark,
        .btn-product-light {
            width: 100%;
        }

        .latest-products-heading {
            margin-top: 56px;
        }

        .product-mini-card {
            min-height: auto;
        }
    }
</style>
{% endblock %}