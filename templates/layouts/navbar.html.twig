{# ................. NAVBAR  ........................... #}
<nav class="navbar navbar-expand-lg navbar-dark fixed-top custom-navbar">
    <!-- Logo -->
    <a class="navbar-brand" href="{{ path('app_home_page') }}">
        <img src="{{ asset('uploads/images/LOGO VILLA SENSE.png') }}" alt="Logo" class="logo-navbar">
    </a>

    <div class="container">
        <!-- Burger menu -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarLuxury"
                aria-controls="navbarLuxury" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- Menu -->
        <div class="collapse navbar-collapse" id="navbarLuxury">
            <ul class="navbar-nav mx-auto">

                <!-- Menu fixe La Villa -->
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" id="navHebergement" role="button"
                       data-bs-toggle="dropdown" aria-expanded="false">
                        La Villa Sense
                    </a>

                    <ul class="dropdown-menu" aria-labelledby="navHebergement">
                        <li>
                            <a class="dropdown-item" href="{{ path('villa_58') }}">
                                La Villa
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item" href="#">
                                Activités & excursions
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item" href="#">
                                Activités
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item" href="#">
                                Excursions
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item" href="#">
                                Bien-être
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item" href="#">
                                Pour les enfants
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item" href="#">
                                Les options
                            </a>
                        </li>
                    </ul>
                </li>

                <!-- Notre boutique -->
                {% if categories is defined %}
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="categoriesDropdown" role="button"
                           data-bs-toggle="dropdown" aria-expanded="false">
                            E-shopping
                        </a>

                        <ul class="dropdown-menu" aria-labelledby="categoriesDropdown">
                            {% for category in categories %}
                                <li>
                                    <h6 class="dropdown-header">
                                        {{ category.name }}
                                    </h6>
                                </li>

                                {% if category.subCategories|length > 0 %}
                                    {% for subCategory in category.subCategories %}
                                        <li>
                                            <a class="dropdown-item"
                                               href="{{ path('app_home_product_filter', {'id': subCategory.id}) }}">
                                                {{ subCategory.name }}
                                            </a>
                                        </li>
                                    {% endfor %}
                                {% else %}
                                    <li>
                                        <span class="dropdown-item text-muted">
                                            Aucune sous-catégorie
                                        </span>
                                    </li>
                                {% endif %}

                                {% if not loop.last %}
                                    <li><hr class="dropdown-divider"></li>
                                {% endif %}
                            {% endfor %}
                        </ul>
                    </li>
                {% endif %}

                <!-- Espace utilisateur -->
                {% if app.user %}
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button"
                           data-bs-toggle="dropdown" aria-expanded="false">
                            Mon compte
                        </a>

                        <ul class="dropdown-menu" aria-labelledby="userDropdown">
                            <li>
                                <a class="dropdown-item" href="{{ path('app_profile') }}">
                                    Mon profil
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item" href="{{ path('app_user_profile_edit') }}">
                                    Modifier mon profil
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item" href="{{ path('app_user_orders') }}">
                                    Mes commandes
                                </a>
                            </li>

                            <li><hr class="dropdown-divider"></li>

                            <li>
                                <a class="dropdown-item text-danger" href="{{ path('app_logout') }}">
                                    Déconnexion
                                </a>
                            </li>
                        </ul>
                    </li>
                {% else %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_login') }}">
                            Connexion
                        </a>
                    </li>
                {% endif %}

                <!-- Espace Admin -->
                {% if is_granted('ROLE_ADMIN') %}
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle text-warning" href="#" id="adminDropdown" role="button"
                           data-bs-toggle="dropdown" aria-expanded="false">
                            Admin
                        </a>

                        <ul class="dropdown-menu" aria-labelledby="adminDropdown">
                            {% if is_granted('ROLE_EDITOR') %}
                                <li>
                                    <a class="dropdown-item" href="{{ path('app_orders_show', {'type': 'all'}) }}">
                                        Toutes les commandes
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item" href="{{ path('app_orders_show', {'type': 'pay-on-stripe-not-delivered'}) }}">
                                        Commandes payées non livrées
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item" href="{{ path('app_orders_show', {'type': 'is-completed'}) }}">
                                        Commandes livrées
                                    </a>
                                </li>

                                <li><hr class="dropdown-divider"></li>
                            {% endif %}

                            <li>
                                <a class="dropdown-item" href="{{ path('app_category') }}">
                                    Catégories
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item" href="{{ path('app_category_new') }}">
                                    Ajouter une catégorie
                                </a>
                            </li>

                            <li><hr class="dropdown-divider"></li>

                            <li>
                                <a class="dropdown-item" href="{{ path('app_sub_category_index') }}">
                                    Sous-catégories
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item" href="{{ path('app_sub_category_new') }}">
                                    Ajouter une sous-catégorie
                                </a>
                            </li>

                            <li><hr class="dropdown-divider"></li>

                            <li>
                                <a class="dropdown-item" href="{{ path('app_product_index') }}">
                                    Produits
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item" href="{{ path('app_product_new') }}">
                                    Ajouter un produit
                                </a>
                            </li>

                            <li><hr class="dropdown-divider"></li>

                            <li>
                                <a class="dropdown-item" href="{{ path('app_user') }}">
                                    Utilisateurs
                                </a>
                            </li>
                        </ul>
                    </li>
                {% endif %}
            </ul>

            <!-- Bonjour utilisateur -->
            <div class="d-flex align-items-center gap-3 me-3">
                {% if app.user %}
                    <span class="text-white small">
                        Bonjour,
                        {{ app.user.firstName ?? app.user.lastName ?? app.user.email }}
                    </span>
                {% endif %}
            </div>

            <!-- Barre de recherche -->
            <form class="d-flex me-3" role="search" action="{{ path('app_search_engine') }}" method="post">
                <input class="form-control me-2" type="search" name="word" placeholder="Rechercher..." aria-label="Search">
                <button class="btn btn-outline-light" type="submit" data-turbo="false">
                    Rechercher
                </button>
            </form>

            <!-- Panier -->
            <a href="{{ path('app_cart') }}" class="panierNav text-danger text-decoration-none position-relative big">
                🛒
                {% if app.session and app.session.get('cart') is not empty %}
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                        {{ app.session.get('cart')|length }}
                    </span>
                {% endif %}
            </a>
        </div>
    </div>
</nav>